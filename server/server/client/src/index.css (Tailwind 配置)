@tailwind base;
@tailwind components;
@tailwind utilities;

/* 全局样式 */
body {
  @apply bg-gray-50;
}

/* 按钮样式 */
.btn-primary {
  @apply bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition;
}

.btn-danger {
  @apply bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 transition;
}

.btn-secondary {
  @apply bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700 transition;
}

/* 菜单样式 */
.menu-item {
  @apply bg-white p-4 rounded-lg shadow-sm flex justify-between items-center mb-3;
}

.menu-item.completed {
  @apply bg-red-50 border border-red-200;
}

.submenu {
  @apply pl-4 mt-2 bg-gray-50 p-3 rounded-lg mb-3;
}
